scalar DateTime

type Mutation {
  addStation(input: StationInput!): Station
  updateStation(input: StationInput!): Station
  deleteStation(_id: ID!): Boolean
  addFlight(input: FlightInput!): Flight
  deleteFlight(_id: ID!): Boolean
}

type Query {
  getStationById(_id: ID!) : Station
  listStations : [Station]
  listFlightsByArrivalStation(arrivalStation : Reference) : [Flight]
  listFlights : [Flight]
  getFlightById(_id: ID!) : Flight
